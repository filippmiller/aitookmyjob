PORT=8080
SITE_TITLE=AI Took My Job
SITE_TAGLINE=The human cost of artificial intelligence
DEFAULT_COUNTRY=global
DEFAULT_LANG=en

# Security — CHANGE THESE before deploying
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=change-me-admin-token
AUTH_SECRET=change-me-auth-secret

# Database — leave empty for file-based JSON storage (dev mode)
# For PostgreSQL: postgresql://user:password@host:5432/dbname
DATABASE_URL=
PG_SSL=false

# Phone verification — set to true to allow dev OTP codes in responses
ALLOW_DEV_OTP=true

# Production settings
# NODE_ENV=production
# REQUIRE_STRICT_SECRETS=true
# ENABLE_HSTS=true
# CORS_ORIGINS=https://your-domain.com
# BASE_URL=https://your-domain.com

# Daily AI displacement news ingest (PostgreSQL only)
# Uses GDELT public news search by default. Set false to disable in-process refresh.
NEWS_INGEST_ENABLED=true
NEWS_INGEST_INTERVAL_HOURS=24
NEWS_INGEST_DAYS_BACK=14
NEWS_INGEST_MAX_RECORDS=25

# Telegram bot (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_MOD_CHAT_ID=
